{
  "name": "@norish/api",
  "version": "0.17.0-beta",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./logger": "./src/logger.ts",
    "./parser": "./src/parser/index.ts",
    "./ai/providers": "./src/ai/providers/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json --noCheck",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "typecheck": "tsc --noEmit --noCheck",
    "clean": "git clean -xdf .cache .turbo node_modules dist",
    "test": "vitest run --config ./vitest.config.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/azure": "^3.0.31",
    "@ai-sdk/deepseek": "^2.0.20",
    "@ai-sdk/google": "^3.0.30",
    "@ai-sdk/groq": "^3.0.24",
    "@ai-sdk/mistral": "^3.0.20",
    "@ai-sdk/openai": "^3.0.30",
    "@ai-sdk/openai-compatible": "^2.0.30",
    "@ai-sdk/perplexity": "^3.0.19",
    "@norish/auth": "workspace:*",
    "@norish/config": "workspace:*",
    "@norish/db": "workspace:*",
    "@norish/i18n": "workspace:*",
    "@norish/queue": "workspace:*",
    "@norish/shared": "workspace:*",
    "@norish/trpc": "workspace:*",
    "@trpc/server": "catalog:",
    "ai": "^6.0.95",
    "bullmq": "catalog:",
    "cheerio": "1.2.0",
    "drizzle-orm": "catalog:",
    "ffmpeg-static": "^5.3.0",
    "fuse.js": "catalog:",
    "heic-convert": "^2.1.0",
    "html-entities": "catalog:",
    "ioredis": "catalog:",
    "jszip": "catalog:",
    "microdata-node": "2.0.0",
    "mime": "4.1.0",
    "next": "catalog:",
    "ollama-ai-provider-v2": "^3.3.1",
    "openai": "6.22.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "playwright-core": "npm:rebrowser-playwright-core@^1.52.0",
    "sharp": "^0.34.5",
    "superjson": "catalog:",
    "tsdav": "^2.1.8",
    "uuid": "13.0.0",
    "ws": "catalog:",
    "yt-dlp-wrap": "^2.3.12",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@norish/eslint-config": "workspace:*",
    "@norish/prettier-config": "workspace:*",
