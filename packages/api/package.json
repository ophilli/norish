    "@norish/tsconfig": "workspace:*",
    "@types/heic-convert": "^2.1.0",
    "@types/ws": "8.18.1",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@norish/prettier-config"
}
